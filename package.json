    "format": "nx format:write",
    "graph": "nx graph",
    "migration:generate": "TS_NODE_PROJECT=apps/backend/tsconfig.app.json typeorm-ts-node-commonjs -d apps/backend/src/database/data-source.ts migration:generate apps/backend/src/database/migrations/$npm_config_name",
    "migration:run": "TS_NODE_PROJECT=apps/backend/tsconfig.app.json typeorm-ts-node-commonjs -d apps/backend/src/database/data-source.ts migration:run",
    "migration:revert": "TS_NODE_PROJECT=apps/backend/tsconfig.app.json typeorm-ts-node-commonjs -d apps/backend/src/database/data-source.ts migration:revert",
    "migration:show": "TS_NODE_PROJECT=apps/backend/tsconfig.app.json typeorm-ts-node-commonjs -d apps/backend/src/database/data-source.ts migration:show"
  },
